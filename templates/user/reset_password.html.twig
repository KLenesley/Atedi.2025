{% extends 'base.html.twig' %}

{% block title %}Réinitialisation du mot de passe{% endblock %}

{% block body %}
<form method="post" class="w-50 mx-auto text-center">
    <div class="sign-in row align-items-center">
        <div class="col">
            <h1 class="h1 my-5 font-weight-normal">ATEDI</h1>
            <p class="text-muted mb-4">Choisissez un nouveau mot de passe pour votre compte.</p>

            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="alert alert-{{ label == 'error' ? 'danger' : label }}">{{ message }}</div>
                {% endfor %}
            {% endfor %}

            {% for error in resetForm.plainPassword.first.vars.errors %}
                <div class="alert alert-danger">{{ error.message }}</div>
            {% endfor %}
            {% for error in resetForm.plainPassword.second.vars.errors %}
                <div class="alert alert-danger">{{ error.message }}</div>
            {% endfor %}
            {% for error in resetForm.plainPassword.vars.errors %}
                <div class="alert alert-danger">{{ error.message }}</div>
            {% endfor %}

            <div class="input-group mb-3">
                <div class="input-group-prepend">
                    <span class="input-group-text"><i class="fas fa-lock"></i></span>
                </div>
                {{ form_widget(resetForm.plainPassword.first, {'attr': {'placeholder': 'Nouveau mot de passe', 'class': 'form-control'}}) }}
            </div>

            <div class="input-group mb-3">
                <div class="input-group-prepend">
                    <span class="input-group-text"><i class="fas fa-lock"></i></span>
                </div>
                {{ form_widget(resetForm.plainPassword.second, {'attr': {'placeholder': 'Confirmer le mot de passe', 'class': 'form-control'}}) }}
            </div>

            {{ form_rest(resetForm) }}

            <button class="green-btn py-2 text-center w-50 mb-4" type="submit">Enregistrer le mot de passe</button>
        </div>
    </div>
</form>
{% endblock %}
