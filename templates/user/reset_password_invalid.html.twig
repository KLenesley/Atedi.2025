{% extends 'base.html.twig' %}

{% block title %}Lien invalide{% endblock %}

{% block body %}
<div class="w-50 mx-auto text-center mt-5">
    <div class="alert alert-danger py-4">
        <h4 class="alert-heading mb-3"><i class="fas fa-exclamation-triangle mr-2"></i>Lien invalide ou expiré</h4>
        <p>Ce lien de réinitialisation de mot de passe est invalide ou a expiré (durée de validité : 1 heure).</p>
        <hr>
        <p class="mb-0">Veuillez contacter votre administrateur pour obtenir un nouveau lien.</p>
    </div>
    <a href="{{ path('app_login') }}" class="grey-btn py-2 px-4">Retour à la connexion</a>
</div>
{% endblock %}
